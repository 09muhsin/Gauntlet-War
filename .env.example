# ---- Gauntlet War — environment template ----
# Copy to ".env" and fill in real values. NEVER commit ".env" (it is gitignored).

# Band — Agent API base
BAND_API_BASE=https://app.band.ai/api/v1/agent

# Each Band remote agent has its own ID + api_key + full handle.
BAND_CONDUCTOR_ID=
BAND_CONDUCTOR_KEY=
BAND_CONDUCTOR_HANDLE=@you/conductor

BAND_STRATEGIST_A_ID=
BAND_STRATEGIST_A_KEY=
BAND_STRATEGIST_A_HANDLE=@you/strategista

BAND_STRATEGIST_B_ID=
BAND_STRATEGIST_B_KEY=
BAND_STRATEGIST_B_HANDLE=@you/strategistb

BAND_STRATEGIST_C_ID=
BAND_STRATEGIST_C_KEY=
BAND_STRATEGIST_C_HANDLE=@you/strategistc

BAND_SCORER_ID=
BAND_SCORER_KEY=
BAND_SCORER_HANDLE=@you/scorer

# AI/ML API — Conductor + Strategist reasoning (claim coupon via lablab.ai)
AIML_API_KEY=
AIML_API_BASE=https://api.aimlapi.com/v1
# Strong route = authoring, synthesis, deliverables. Sonnet 4.6 is ~5x cheaper than Opus 4.8 and
# still very human — a safe default for a limited key. Use claude-opus-4-8 only for a final run.
AIML_MODEL_STRONG=claude-sonnet-4-6
AIML_MODEL_CHEAP=gpt-4o-mini

# Featherless AI — Scorer + personas (promo BOA26). Leave blank if you don't have it yet.
FEATHERLESS_API_KEY=
FEATHERLESS_API_BASE=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Scorer runs on "featherless" (preferred, prize-eligible) or "aiml" (fallback if no key).
SCORER_PROVIDER=featherless

# Keep debate tight to protect the AI/ML API credit budget.
MAX_DEBATE_ROUNDS=1
# Self-improvement passes: after the debate, strategists revise their plans to fix critiques.
REFINE_PASSES=1
# Deliverable spend knob: lite (1 call/deliverable) | standard (~3-4) | max (~5-6). Start lite to
# sanity-check output cheaply, then bump to standard/max for the final, polished run.
CREATIVE_DEPTH=standard
